{
  "name": "spotify-embedded",
  "version": "1.0.0",
  "description": "Self-hosted API exposing your Spotify listening activity for portfolio sites",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "auth": "ENABLE_AUTH_ROUTES=true tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "spotify",
    "api",
    "portfolio",
    "gemini",
    "now-playing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.4.0",
    "groq-sdk": "^1.2.1",
    "js-yaml": "^4.1.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
