# ── Spotify ──────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:3000/auth/callback as a Redirect URI (localhost is not allowed)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Obtained by running: npm run auth  (see README for the full setup flow)
SPOTIFY_REFRESH_TOKEN=your_refresh_token

# ── Groq (LLM for mood generation) ───────────────────────────────────────────
# Free API key from https://console.groq.com (no credit card required)
GROQ_API_KEY=your_groq_api_key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Set to true only when running: npm run auth (one-time Spotify OAuth setup)
ENABLE_AUTH_ROUTES=false

# Restrict to your portfolio domain in production (e.g. https://yoursite.com)
CORS_ORIGIN=*
